# Shared BANNED/ALLOWED regex constants for the delete-node-removal-discipline
# CI gate (Spec 19). Sourced by both the CI workflow step and the
# violation-fires sentinel test, so the two cannot drift silently.
# Per CLAUDE.md §5: validation patterns used by more than one consumer must
# live in a single source-of-truth file.

# Banned strings — every reference to the singular DeleteNode path that
# Spec 19 Task 16 removed. Each identifier is anchored with `\b` (word
# boundary) so the singular forms do NOT match the plural variants
# (e.g., `DeleteNode\b` rejects `DeleteNode` but accepts `DeleteNodes`).
# The `store\.deleteNode\(` arm already anchors via the literal `(`.
export BANNED='DeleteNode\b|delete_node\b|DeleteNodeInput\b|createDeleteNodeOp\b|store\.deleteNode\('

# Allow-list of paths where banned strings legitimately appear (this spec,
# governance docs, the sentinel script itself, the workflow file, and this
# shared env file). The production grep scans only `crates/` and `frontend/`
# with `--include='*.rs|*.ts|*.tsx'`, so the .md/.claude/.github entries are
# defense-in-depth in case the scope ever widens.
export ALLOWED='docs/superpowers/specs/2026-05-27-19-delete-nodes\.md|docs/superpowers/reviews/2026-05-27-pr-68-delete-nodes\.md|CLAUDE\.md|\.claude/rules/|\.github/workflows/scripts/test-delete-node-removal-discipline\.sh|\.github/workflows/scripts/delete-node-removal-discipline\.env|\.github/workflows/ci\.yml|frontend/src/operations/__tests__/operation-types\.test-d\.ts'
